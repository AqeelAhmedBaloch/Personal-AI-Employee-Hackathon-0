# Local Agent Configuration
# Platinum Tier - Local Deployment (Your Machine)

# IMPORTANT: This is the FINAL ACTION local agent
# HAS sending capabilities
# HAS banking credentials
# HAS WhatsApp session
# THESE CREDENTIALS NEVER SYNC TO CLOUD

# Gmail Configuration (FULL ACCESS)
GMAIL_CLIENT_ID=your_local_gmail_client_id
GMAIL_CLIENT_SECRET=your_local_gmail_secret
GMAIL_SCOPES=gmail.readonly,gmail.compose,gmail.send
# Note: gmail.send scope INCLUDED for final sending

# WhatsApp Session
WHATSAPP_SESSION_PATH=/path/to/whatsapp/session
# CRITICAL: Never sync this folder!

# Banking Configuration
BANK_API_URL=https://api.yourbank.com
BANK_API_TOKEN=your_banking_api_token
# CRITICAL: Never sync these credentials!

# Payment Gateway
STRIPE_SECRET_KEY=sk_test_xxx
PAYPAL_CLIENT_ID=your_paypal_client_id
# CRITICAL: Never sync these credentials!

# Social Media (FULL ACCESS)
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
FACEBOOK_ACCESS_TOKEN=your_facebook_token
TWITTER_API_KEY=your_twitter_key
# These can post directly

# Local Agent Settings
AGENT_TYPE=local
MODE=final_action
SYNC_ENABLED=true
VAULT_SYNC_PATH=/path/to/AI_Employee_Vault

# Approval Settings
REQUIRE_APPROVAL_FOR_PAYMENTS=true
APPROVAL_THRESHOLD=100.00
REQUIRE_APPROVAL_FOR_EMAIL_SEND=true
REQUIRE_APPROVAL_FOR_SOCIAL_POST=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=Logs/local_agent.log

# Dashboard (Single Writer)
DASHBOARD_WRITE_ENABLED=true
