# Cloud Agent Configuration
# Platinum Tier - Cloud Deployment (Oracle/AWS VM)

# IMPORTANT: This is the DRAFT-ONLY cloud agent
# NO sending capabilities
# NO banking credentials
# NO WhatsApp session

# Gmail Configuration (READ + DRAFT ONLY)
GMAIL_CLIENT_ID=your_cloud_gmail_client_id
GMAIL_CLIENT_SECRET=your_cloud_gmail_secret
GMAIL_SCOPES=gmail.readonly,gmail.compose
# Note: gmail.send scope NOT included for security

# Social Media (DRAFT ONLY)
LINKEDIN_CLIENT_ID=your_cloud_linkedin_client_id
LINKEDIN_SCOPES=w_member_social,r_basicprofile
# Posts will be drafted, not published

# Database Configuration (Optional)
DB_HOST=localhost
DB_NAME=ai_employee_cloud
DB_USER=cloud_agent
DB_PASSWORD=your_db_password

# Cloud Agent Settings
AGENT_TYPE=cloud
MODE=draft_only
SYNC_ENABLED=true
VAULT_SYNC_PATH=/home/ubuntu/ai_employee/AI_Employee_Vault

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/ai_employee/cloud_agent.log

# Health Check
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_ENDPOINT=/health
