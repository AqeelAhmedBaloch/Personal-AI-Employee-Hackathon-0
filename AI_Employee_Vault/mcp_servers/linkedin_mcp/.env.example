# LinkedIn API Configuration
# Get credentials from: https://www.linkedin.com/developers/apps

# LinkedIn Client ID (from your app)
LINKEDIN_CLIENT_ID=your_client_id_here

# LinkedIn Client Secret (from your app)
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# LinkedIn Access Token (generated via OAuth)
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# LinkedIn Person URN (optional - auto-detected if not set)
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID

# Legacy Browser Automation (not recommended)
LINKEDIN_EMAIL=aqeelwork2026@gmail.com
LINKEDIN_PASSWORD=Work@206

# Dry Run Mode
DRY_RUN=false
